{
  "expo": {
    "name": "ANTIGRAM",
    "slug": "antigram",
    "version": "1.0.0",
    "owner": "antigram",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0F05"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.antigram.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSCameraUsageDescription": "ANTIGRAM использует камеру для съёмки моментов.",
        "NSPhotoLibraryUsageDescription": "ANTIGRAM использует галерею для выбора и сохранения фото.",
        "NSPhotoLibraryAddUsageDescription": "ANTIGRAM сохраняет фото в твою галерею.",
        "NSMicrophoneUsageDescription": "ANTIGRAM может использовать микрофон при съёмке видео."
      }
    },
    "android": {
      "package": "com.antigram.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0F05"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-av",
      [
        "expo-media-library",
        {
          "photosPermission": "ANTIGRAM хочет сохранить фото в твою галерею.",
          "savePhotosPermission": "ANTIGRAM хочет сохранить фото в твою галерею.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#c9843e",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6f65b4db-7c33-4df1-b866-059c39fc653c"
      }
    }
  }
}
